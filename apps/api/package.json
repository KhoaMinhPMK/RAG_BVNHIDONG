{
  "name": "webrag-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@3.6.4",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/scripts/seed-episodes.ts",
    "backfill:artifacts": "tsx src/scripts/backfill-document-artifacts.ts",
    "upload:downloads-pdfs": "tsx src/scripts/upload-downloads-pdfs-to-storage.ts",
    "backfill:storage-path-downloads": "tsx src/scripts/backfill-storage-path-from-downloads.ts",
    "benchmark:retrieval": "tsx src/scripts/benchmark-knowledge-ranking.ts",
    "eval:rag": "tsx src/scripts/eval-rag.ts",
    "eval:rag:json": "tsx src/scripts/eval-rag.ts --json",
    "test:detection": "tsx src/scripts/test-detection.ts",
    "test:knowledge": "tsx src/scripts/test-knowledge.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@types/multer": "^2.1.0",
    "cli-progress": "^3.12.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "gray-matter": "^4.0.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "marked": "^18.0.3",
    "multer": "^2.1.1",
    "pdf-parse": "1.1.1",
    "tiktoken": "^1.0.22",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "ioredis-mock": "^8.9.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
