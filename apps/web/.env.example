# ─── Supabase ──────────────────────────────────────────────────────────────────
# Lấy tại: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<your-anon-key>

# ─── Backend API ───────────────────────────────────────────────────────────────
# URL của Express API (apps/api). Mặc định: http://localhost:3005
NEXT_PUBLIC_API_URL=http://localhost:3005

# ─── Dev / Demo mode (tuỳ chọn) ───────────────────────────────────────────────
# Đặt true để bỏ qua Supabase auth — tiện khi dev mà chưa có credentials
# NEXT_PUBLIC_SKIP_AUTH=true
# NEXT_PUBLIC_DEV_ROLE=admin   # clinician | radiologist | researcher | admin

# ─── Testing ───────────────────────────────────────────────────────────────────
# JWT token giả để test API không cần đăng nhập (chỉ dùng trong dev/test)
# NEXT_PUBLIC_MOCK_JWT_TOKEN=
